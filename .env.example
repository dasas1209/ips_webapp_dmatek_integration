# .env.example — template de configuracao do Metric4 RTLS
# Copia este ficheiro para .env e preenche os valores reais.
# O .env NUNCA deve ser commitado (esta no .gitignore).

# ===========================================================================
# INFLUXDB CLOUD (obrigatorio)
# ===========================================================================

# URL da instancia InfluxDB (ex: https://us-east-1-1.aws.cloud2.influxdata.com/)
INFLUX_URL=https://<regiao>.aws.cloud2.influxdata.com/

# Token de leitura e escrita gerado na UI do InfluxDB
INFLUX_TOKEN=<token-de-leitura-e-escrita>

# Organizacao InfluxDB (email ou org ID)
INFLUX_ORG=<email-ou-org-id>

# Nome do bucket onde sao gravadas posicoes e eventos de auditoria
INFLUX_BUCKET=<nome-do-bucket>

# ===========================================================================
# AUTENTICACAO JWT (obrigatorio)
# ===========================================================================

# Chave secreta para assinar tokens JWT — DEVE ser aleatoria e longa
# Gera uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<chave-aleatoria-minimo-32-caracteres>

# Duracao do token JWT em horas (default: 2)
# TOKEN_EXPIRY_HOURS=2

# ===========================================================================
# CONTA ADMINISTRADOR DO SISTEMA (opcional — tem defaults seguros para dev)
# ===========================================================================

# ID interno do tenant administrador na tabela clientes
# ADMIN_TENANT_ID=cliente_admin

# Username da conta superadmin
# ADMIN_USERNAME=admin

# Password da conta superadmin — ALTERAR em producao
# ADMIN_PASSWORD=admin

# ===========================================================================
# SERVIDOR WEBSOCKET DMATEK (obrigatorio em producao)
# ===========================================================================

# IP do servidor Dmatek na rede interna da fabrica
IP_SERVIDOR_DMATEK=172.16.0.201

# Porta do servidor Dmatek
PORTA_DMATEK=5002

# Endpoint WebSocket do servidor Dmatek
# ENDPOINT_DMATEK=/TagPosition

# ===========================================================================
# LIMITES DO MAPA (fallback — apenas usados se o mapa nao estiver na BD)
# Cada mapa real tem limite_x/limite_y proprios na tabela mapas do SQLite.
# Estes valores so sao usados por obter_limites_mapa() como ultimo recurso.
# ===========================================================================

# Dimensao horizontal maxima do espaco monitorizado em centimetros
# LIMITE_X_CM=760.0

# Dimensao vertical maxima do espaco monitorizado em centimetros
# LIMITE_Y_CM=500.0

# ===========================================================================
# MOTOR DE KPIS E DETECCAO DE MOVIMENTO (opcional — tem defaults razoaveis)
# ===========================================================================

# Distancia minima entre leituras consecutivas para contar como movimento (cm)
# LIMIAR_MOVIMENTO_CM=50.0

# Segundos sem sinal para marcar tag EM MOVIMENTO como offline
# TIMEOUT_MOVIMENTO=1

# Segundos sem sinal para marcar tag EM REPOUSO como offline
# TIMEOUT_REPOUSO=70

# Duracao do turno actual para calculo de KPIs (horas)
# JANELA_KPI_HORAS=8

# Maximo de dias de historico consultavel via /relatorio/dados
# LIMITE_DIAS_HISTORICO=30

# Maximo de pontos de rasto enviados ao frontend por query
# MAX_RASTO_PONTOS=5000

# ===========================================================================
# WORKER DE ESCUTA (opcional)
# ===========================================================================

# Intervalo em segundos entre recargas do mapeamento tag->tenant da BD
# MATRIZ_RELOAD_INTERVAL_SEG=300

# ===========================================================================
# LIMITES DE UPLOAD E QUERIES (opcional)
# ===========================================================================

# Tamanho maximo do avatar em bytes (default: 2097152 = 2 MB)
# MAX_AVATAR_BYTES=2097152

# Maximo de registos devolvidos pelo log de auditoria global
# AUDIT_LOG_INFLUX_LIMIT=10000

# Maximo de registos devolvidos pelo log de sessoes por tenant
# SESSIONS_LOG_LIMIT=500

# ===========================================================================
# BUILD E IDENTIFICACAO (opcional)
# ===========================================================================

# Identificador de versao exibido em /api/health e no log de arranque
# API_BUILD_ID=dev

# ===========================================================================
# CORS (opcional — por defeito permite apenas localhost)
# ===========================================================================

# Origens permitidas separadas por virgula
# Em producao, define apenas as origens reais do frontend
# CORS_ORIGINS=http://localhost:8000,https://rtls.metric4.pt
